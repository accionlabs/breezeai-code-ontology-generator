diff --git a/node_modules/tree-sitter/binding.gyp b/node_modules/tree-sitter/binding.gyp
index bb40aa7..de740a6 100644
--- a/node_modules/tree-sitter/binding.gyp
+++ b/node_modules/tree-sitter/binding.gyp
@@ -1,3 +1,35 @@
+# ---------------------------------------------------------------------------
+# PATCHED by breezeai-code-ontology-generator via patch-package.
+# See patches/tree-sitter+0.25.0.patch in the repo root.
+#
+# Why this patch exists:
+#   tree-sitter@0.25.0 specifies "-std=c++17" in three places in binding.gyp.
+#   Node 24's V8 headers use C++20 features (e.g. concepts in <v8.h>), so
+#   compiling the runtime binding against Node 24 with -std=c++17 produces
+#   a broken artifact: node-gyp-build's post-compile verification then fails
+#   with `Error: No native build was found for ... abi=137`. This kills
+#   `npm install` before any lifecycle scripts (including patch-package
+#   itself) get a chance to run, so users on Node 24 see a silent failure
+#   when invoking via `npx -y github:...`.
+#
+#   This patch flips c++17 -> c++20 in all three blocks (Linux/default,
+#   macOS xcode_settings, Windows msvs_settings). gcc 9+, clang 10+, and
+#   MSVC 2019+ all support -std=c++20 cleanly.
+#
+# Why we patch instead of upgrading:
+#   - The fix is already on tree-sitter's main branch (commit f8805e7,
+#     "cxxstd refactor") but it has not been published to npm.
+#   - The maintainers attempted to publish 0.25.1 but the npm publish
+#     workflow fails with an OIDC trusted-publishing configuration error
+#     (see https://github.com/tree-sitter/node-tree-sitter/issues/276).
+#   - 0.25.0 has been the "latest" on npm since 2025-06-02 with no
+#     successful release since.
+#   - Tracked at https://github.com/tree-sitter/node-tree-sitter/issues/268
+#     (open). Multiple users carry the same `patch-package` workaround.
+#
+#   When 0.25.1 (or any version > 0.25.0) ships, patch-package will refuse
+#   to apply this and you can delete patches/tree-sitter+0.25.0.patch.
+# ---------------------------------------------------------------------------
 {
   "targets": [
     {
@@ -25,13 +57,13 @@
         "NAPI_VERSION=<(napi_build_version)",
       ],
       "cflags_cc": [
-        "-std=c++17"
+        "-std=c++20"
       ],
       "conditions": [
         ["OS=='mac'", {
           "xcode_settings": {
             "GCC_SYMBOLS_PRIVATE_EXTERN": "YES", # -fvisibility=hidden
-            "CLANG_CXX_LANGUAGE_STANDARD": "c++17",
+            "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
             "MACOSX_DEPLOYMENT_TARGET": "10.9",
           },
         }],
@@ -39,7 +71,7 @@
           "msvs_settings": {
             "VCCLCompilerTool": {
               "AdditionalOptions": [
-                "/std:c++17",
+                "/std:c++20",
               ],
               "RuntimeLibrary": 0,
             },
